# ==========================================
# 🚀 Hama Chamber Platform - Backend Config
# ==========================================
# This file serves as a template for environment variables.
# Do NOT place actual secrets in this file. 
# Copy this file to `.env` or `.env.local` to use it.

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# The port the backend server will run on (Default: 3000)
PORT=3000

# The URL(s) of the frontend application. Used for CORS configuration.
# Multiple URLs can be separated by commas.
# Example: http://localhost:5173,https://admin.hamachamber.com
FRONTEND_URL=http://localhost:5173

# The current environment (development | production)
NODE_ENV=development

# ------------------------------------------
# Database Configuration (PostgreSQL/Prisma)
# ------------------------------------------
# Connection string for your PostgreSQL database.
DATABASE_URL="postgresql://user:password@localhost:5432/hama_chamber?schema=public"

# ------------------------------------------
# Security & Authentication
# ------------------------------------------
# A highly secure, random string used to sign JSON Web Tokens.
JWT_SECRET="generate_a_secure_random_secret_here"

# The number of bcrypt salt rounds for password hashing (Default: 10)
BCRYPT_SALT_ROUNDS=10

# ------------------------------------------
# Default Admin Credentials (Initial Setup)
# ------------------------------------------
# Used when calling the /api/v1/auth/init-admin endpoint for the first time.
DEFAULT_ADMIN_EMAIL="admin@hamachamber.com"
DEFAULT_ADMIN_PASSWORD="admin_secure_password_123"

# ------------------------------------------
# Media Uploads (Cloudinary)
# ------------------------------------------
# The Cloudinary URL for media storage. Obtain this from your Cloudinary dashboard.
# Format: cloudinary://my_key:my_secret@my_cloud_name
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------
# Used for sending notifications, password resets, etc.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="no-reply@hamachamber.com"
SMTP_PASS="smtp_password_here"
